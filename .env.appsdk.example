# Apps SDK MCP Server Configuration

# Server port (default: 3001)
PORT=3001
MCP_PORT=3001

# Server host (default: 0.0.0.0)
HOST=0.0.0.0
MCP_HOST=0.0.0.0

# Base URL for the server (used in production)
# MCP_BASE_URL=https://your-domain.com

# Node environment
NODE_ENV=development

# Enable MCP traffic locally
MCP_ENABLED=true
